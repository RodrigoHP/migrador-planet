{
  "$schema": "http://json-schema.org/draft-04/schema",
  "title": "Estudo Loja",
  "type": "object",
  "properties": {
    "Simulacao": {
      "properties": {
        "NomeProponente": {
          "type": "string",
          "additionalProperties": false
        },
        "IdadeProponente": {
          "type": "string"
        },
        "Periodicidade": {
          "type": "string"
        },
        "RendaMensal": {
          "type": "string"
        },
        "DataSimulacao": {
          "type": "string",
          "pattern": "^(?:(?:31(\\/|-|\\.)(?:0?[13578]|1[02]))\\1|(?:(?:29|30)(\\/|-|\\.)(?:0?[13-9]|1[0-2])\\2))(?:(?:1[6-9]|[2-9]\\d)?\\d{2})$|^(?:29(\\/|-|\\.)0?2\\3(?:(?:(?:1[6-9]|[2-9]\\d)?(?:0[48]|[2468][048]|[13579][26])|(?:(?:16|[2468][048]|[3579][26])00))))$|^(?:0?[1-9]|1\\d|2[0-8])(\\/|-|\\.)(?:(?:0?[1-9])|(?:1[0-2]))\\4(?:(?:1[6-9]|[2-9]\\d)?\\d{2})$"
        },
        "TotalContribuicao": {
          "type": "string"
        },
        "coberturas": {
          "type":"object",
          "items": {
            "type":"array",
            "additionalProperties": false,
            "required":["nome", "indenizacao", "contribuicao", "descricao"],
            "properties": {
              "nome": {
                "type": "string"
              },
              "indenizacao": {
                "type": "number"
                
              },
              "contribuicao": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [ "NomeProponente", "IdadeProponente", "Periodicidade", "RendaMensal", "DataSimulacao", "TotalContribuicao", "coberturas" ]
    }
  }  
}
